{
  "name": "@mailloop/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for the Mailloop email testing platform",
  "author": "Mailloop <support@mailloop.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mailloop/sdk-js.git"
  },
  "keywords": [
    "mailloop",
    "email",
    "testing",
    "sdk",
    "api"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "dotenv": "^16.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
