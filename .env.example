# Mailloop SDK E2E Test Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your Mailloop API key (required)
# Get one from: https://mailloop.io/app/settings/organization
MAILLOOP_API_KEY=ml_your_api_key_here

# API base URL
MAILLOOP_BASE_URL=https://api.mailloop.io/v1
